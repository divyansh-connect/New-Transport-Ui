{
  "expo": {
    "name": "Driver Life Tracking System",
    "slug": "driver-life-tracking-system-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kiaan.driverlifetracking"
    },
    "android": {
      "backgroundColor": "#0F172A",
      "package": "com.kiaan.driverlifetracking",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "scheme": "driver-life-app",
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Driver Life to use your location for live tracking on map."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d96b6da1-36f0-425d-910e-81017d3532a0"
      }
    },
    "owner": "yash_ji"
  }
}
